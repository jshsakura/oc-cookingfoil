# CookingFoil environment — copy to `.env` and edit.
# All variables use the COOK_ prefix.

# Logging (uses the `debug` library namespace).
DEBUG=oc-cookingfoil*

# Host port published by docker-compose. Container always listens on 80.
COOK_HOST_PORT=9080

# Inside-container port. The container always overrides to 80 via Dockerfile
# ENV; this value is what local `npm start` / `npm run dev` and Playwright CI
# bind to, so it MUST be unprivileged (>= 1024) to avoid EACCES on non-root.
COOK_PORT=3001

# Where game files live. Default (unset) resolves to ./games relative to
# wherever you start the server. The Docker image overrides this to /games
# via ENV in the Dockerfile, so leave it unset for local development.
# COOK_GAMES_DIR=./games

# Persistent runtime cache (extracted icons + titledb).
COOK_DATA_DIR=/data

# Switch console keys folder (read-only). Drop prod.keys into ./keys/.
COOK_KEYS_DIR=/keys

# Optional path to user-supplied custom shop entries (homebrew, fan content).
# Defaults to ${COOK_GAMES_DIR}/custom_entries.jsonc when unset.
COOK_CUSTOM_ENTRIES=

# Display-language preference for NACP / titledb merge (first match wins).
# Examples: "ko,en,ja"  or  "en,ja"  or  "ja,en"
COOK_LANG_PRIORITY=ko,en,ja

# Basic auth. Empty = no auth. Format: "user:pass,user2:pass2".
COOK_AUTH_USERS=

# Messages.
COOK_UNAUTHORIZED_MSG=No tricks and treats for you!!
COOK_WELCOME_MSG=CookingFoil is serving fresh.

# --- Community titledb (blawar/titledb) ---
# Region/lang files to fetch + merge. First match per field wins, falling
# back through COOK_LANG_PRIORITY. Default fetches a sensible global set.
COOK_TITLEDB_REGIONS=KR.ko,US.en,JP.ja,EU.en,HK.zh

# Set to "false" to never auto-download on cold start (server then runs with
# whatever you've put under ${COOK_DATA_DIR}/titledb/ manually).
COOK_TITLEDB_AUTO_FETCH=true

# --- Security ---
# Behind a reverse proxy? Set to "true" so req.ip honours X-Forwarded-For.
COOK_TRUST_PROXY=false
# How many failed auth attempts before the IP is locked out.
COOK_AUTH_MAX_FAILURES=5
# Auto-unlock after N hours. 0 = forever (admin unlock required).
COOK_LOCKOUT_TTL_HOURS=0
# One-shot: set to "true" to wipe ALL lockouts on next boot. Reset afterwards.
COOK_RESET_LOCKOUTS=false
# Loopback callers (127.0.0.1, ::1) bypass lockout/probe tracking by default —
# they already have local shell access. Set to "false" to enforce strictly.
COOK_LOCKOUT_TRUST_LOOPBACK=true
# Per-IP rate limit (requests/min) and burst budget.
COOK_RATE_LIMIT_PER_MIN=240
COOK_RATE_LIMIT_BURST=60
# Admin token for POST /api/admin/unlock. Unset = admin endpoint disabled.
# Generate with: openssl rand -hex 32
COOK_ADMIN_TOKEN=

# How often to auto-refresh the titledb cache while the server runs.
# Re-scheduling is cache-mtime-aware, so a restart doesn't reset the clock.
# Set to 0 to disable scheduled refresh (cold-start fetch still works).
COOK_TITLEDB_REFRESH_INTERVAL_HOURS=24

# Web-based file uploads (POST /api/uploads → temp/ → Apply → games/).
# Disabled by default. When enabled the upload tray FAB shows up in the
# dashboard. Auth + IP-lockout perimeter still apply.
COOK_UPLOADS_ENABLED=false
# Max single-file upload size in bytes. Default ~32 GiB covers dual-layer
# XCI dumps; lower this if you want a tighter guardrail.
# COOK_UPLOAD_MAX_BYTES=34359738368

# NACP extraction worker concurrency. NRO files always get a pure-JS
# parse. NSP/XCI use nstool below (when configured); NSZ/XCZ stay
# uncovered until a decompress stage lands.
COOK_EXTRACT_CONCURRENCY=2

# Path to an `nstool` binary (jakcron/nstool) for NSP/XCI metadata
# extraction. The shipped Docker image bundles nstool at
# /usr/local/bin/nstool — override only if you're running from source
# with a different install location. If the binary can't be resolved,
# NSP/XCI containers fall back to filename-derived metadata.
COOK_NSTOOL_BIN=/usr/local/bin/nstool
# Path to an `nsz` binary (nicoboss/nsz) for NSZ/XCZ decompression.
# Shipped image bundles nsz via pip at /usr/bin/nsz. NSZ/XCZ are
# decompressed into a tempdir, then handed to the NSP path.
COOK_NSZ_BIN=/usr/bin/nsz
# prod.keys location for NSP/XCI/NSZ/XCZ decryption. Default matches the
# legacy tinfoil-hat /keys mount layout. Required for any keyed
# extractor — the provider checks and skips silently if missing.
COOK_PROD_KEYS_PATH=/keys/prod.keys
# Per-extraction subprocess deadline (ms). Multi-gigabyte XCI dumps
# can legitimately take 30–60 s on slow disks; NSZ decompress adds
# another pass on top. Bump if you see timeouts.
COOK_EXTRACT_TIMEOUT_MS=120000
