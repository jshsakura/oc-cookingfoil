# CookingFoil environment — copy to `.env` and edit.
# All variables use the COOK_ prefix.

# Logging (uses the `debug` library namespace).
DEBUG=oc-cookingfoil*

# Host port published by docker-compose. Container always listens on 80.
COOK_HOST_PORT=9080

# Inside-container port. The container always overrides to 80 via Dockerfile
# ENV; this value is what local `npm start` / `npm run dev` and Playwright CI
# bind to, so it MUST be unprivileged (>= 1024) to avoid EACCES on non-root.
COOK_PORT=3001

# Where game files live. Default (unset) resolves to ./games relative to
# wherever you start the server. The Docker image overrides this to /games
# via ENV in the Dockerfile, so leave it unset for local development.
# COOK_GAMES_DIR=./games

# Persistent runtime cache (extracted icons + titledb).
COOK_DATA_DIR=/data

# Switch console keys folder (read-only). Drop prod.keys into ./keys/.
COOK_KEYS_DIR=/keys

# Optional path to user-supplied custom shop entries (homebrew, fan content).
# Defaults to ${COOK_GAMES_DIR}/custom_entries.jsonc when unset.
COOK_CUSTOM_ENTRIES=

# Display-language preference for NACP / titledb merge (first match wins).
# Examples: "ko,en,ja"  or  "en,ja"  or  "ja,en"
COOK_LANG_PRIORITY=ko,en,ja

# Basic auth. Empty = no auth. Format: "user:pass,user2:pass2".
COOK_AUTH_USERS=

# Messages.
COOK_UNAUTHORIZED_MSG=No tricks and treats for you!!
COOK_WELCOME_MSG=CookingFoil is serving fresh.

# --- Community titledb (blawar/titledb) ---
# Region/lang files to fetch + merge. First match per field wins, falling
# back through COOK_LANG_PRIORITY. Default fetches a sensible global set.
COOK_TITLEDB_REGIONS=KR.ko,US.en,JP.ja,EU.en,HK.zh

# Set to "false" to never auto-download on cold start (server then runs with
# whatever you've put under ${COOK_DATA_DIR}/titledb/ manually).
COOK_TITLEDB_AUTO_FETCH=true

# --- Artwork URLs (CyberFoil/AeroFoil) ---
# The shop hands out ABSOLUTE icon/banner/screenshot URLs so CyberFoil/AeroFoil
# can fetch them (they curl the per-item URL verbatim; a host-relative path has
# no host to resolve). By default the origin is derived per-request from the
# Host header — leave this unset for the common case. Pin it only when behind a
# proxy that rewrites Host, or to force a canonical address. No trailing slash.
# NOTE: stock Tinfoil ignores per-item icon URLs entirely (its index spec has
# no icon field), so server-served icons only show on CyberFoil/AeroFoil.
#
# Both icon AND file-download URLs are emitted ABSOLUTE (CyberFoil needs a full
# host for icons, and resolves downloads via BuildFullUrl where a relative path
# breaks). The host is auto-derived per request from Host / X-Forwarded-Host, so
# direct IP access needs nothing here. Behind a reverse proxy, either set
# COOK_TRUST_PROXY=true (and have the proxy forward X-Forwarded-Host/Proto) or
# pin this to the exact external address for a guaranteed-correct host.
# COOK_PUBLIC_BASE_URL=http://192.168.1.50:9080

# --- Security ---
# Behind a reverse proxy? Set to "true" so req.ip honours X-Forwarded-For.
COOK_TRUST_PROXY=false
# How many failed auth attempts before the IP is locked out.
COOK_AUTH_MAX_FAILURES=5
# Auto-unlock after N hours. 0 = forever (admin unlock required).
COOK_LOCKOUT_TTL_HOURS=0
# One-shot: set to "true" to wipe ALL lockouts on next boot. Reset afterwards.
COOK_RESET_LOCKOUTS=false
# Loopback callers (127.0.0.1, ::1) bypass lockout/probe tracking by default —
# they already have local shell access. Set to "false" to enforce strictly.
COOK_LOCKOUT_TRUST_LOOPBACK=true
# Per-IP rate limit (requests/min) and burst budget.
COOK_RATE_LIMIT_PER_MIN=240
COOK_RATE_LIMIT_BURST=60
# Admin token for POST /api/admin/unlock. Unset = admin endpoint disabled.
# Generate with: openssl rand -hex 32
COOK_ADMIN_TOKEN=

# --- /admin dashboard (2FA) ---
# The /admin page (per-user access stats, last-seen, lockouts) sits inside the
# basic-auth perimeter and adds a TOTP second factor. Unset = /admin disabled
# (404). Set a base32 secret to enable; on boot the server prints an
# otpauth:// enrollment URI to the logs — scan it into Google Authenticator /
# Aegis / 1Password, then enter the 6-digit code at /admin.
# Generate a secret with:
#   node -e "import('otplib').then(o=>o.generateSecret()).then(console.log)"
COOK_ADMIN_TOTP_SECRET=
# Admin session lifetime (hours) after a successful code. Default 8.
# COOK_ADMIN_SESSION_HOURS=8

# How often to auto-refresh the titledb cache while the server runs.
# Re-scheduling is cache-mtime-aware, so a restart doesn't reset the clock.
# Set to 0 to disable scheduled refresh (cold-start fetch still works).
COOK_TITLEDB_REFRESH_INTERVAL_HOURS=24

# Web-based file uploads (POST /api/uploads → temp/ → Apply → games/).
# Disabled by default. When enabled the upload tray FAB shows up in the
# dashboard. Auth + IP-lockout perimeter still apply.
# This flag ALSO enables title-artwork uploads (icon/banner/screenshot) in the
# per-title detail modal — POST /api/art/<titleId>/<kind>. Uploaded images are
# re-encoded by sharp and stored under ${COOK_DATA_DIR}/custom-art, overriding
# the titledb CDN artwork and NACP-extracted icons.
COOK_UPLOADS_ENABLED=false
# Max single-file upload size in bytes. Default ~32 GiB covers dual-layer
# XCI dumps; lower this if you want a tighter guardrail.
# COOK_UPLOAD_MAX_BYTES=34359738368

# When to pull the icon (and fallback name/publisher) straight out of the
# game container instead of leaning on blawar/titledb's Nintendo CDN URL:
#   all     — extract for EVERY title, so covers render fully OFFLINE and the
#             on-device icon matches the actual file. titledb's CDN URL is a
#             fallback only. Needs prod.keys + nstool (below); degrades to the
#             CDN when they're absent. Requires prod.keys + nstool and
#             needlessly unpacks multi-GB XCI/NSZ — use ONLY on a LAN with no
#             internet, where the CDN is unreachable.
#   missing — extract ONLY titles titledb can't cover (homebrew/fan/synthetic
#             IDs). Retail titles keep their titledb name + Nintendo CDN icon
#             (both already known from the filename's title ID — no unpack).
#             This is the lean default; needs internet to first pull covers.
#   off     — never extract.
# DEFAULT is "missing": don't unpack a 6 GB XCI just to read a name/icon the
# titledb + CDN already have. Set "all" only for an offline LAN shop.
COOK_EXTRACT_ICONS=missing

# --- Publish titledb in the shop response? ---
# OFF by default, and that's intentional. CyberFoil/AeroFoil's legacy parser
# turns EVERY titledb entry into a list item with an empty download url —
# a "ghost" row that can't be selected or installed (A/＋ do nothing on it).
# Per-file entries already carry name + size + titleId + icon_url, and CyberFoil
# pulls richer metadata from its own offline DB, so leaving this off is the
# right call for CyberFoil/AeroFoil. Set to "true" ONLY for stock Tinfoil,
# whose detail view / search reads the titledb override map.
# COOK_EMIT_TITLEDB=true

# NACP extraction worker concurrency. NRO files always get a pure-JS
# parse. NSP/XCI use nstool below (when configured); NSZ/XCZ stay
# uncovered until a decompress stage lands.
COOK_EXTRACT_CONCURRENCY=2

# Path to an `nstool` binary (jakcron/nstool) for NSP/XCI metadata
# extraction. The shipped Docker image bundles nstool at
# /usr/local/bin/nstool — override only if you're running from source
# with a different install location. If the binary can't be resolved,
# NSP/XCI containers fall back to filename-derived metadata.
COOK_NSTOOL_BIN=/usr/local/bin/nstool
# Path to an `nsz` binary (nicoboss/nsz) for NSZ/XCZ decompression.
# Shipped image bundles nsz via pip at /usr/bin/nsz. NSZ/XCZ are
# decompressed into a tempdir, then handed to the NSP path.
COOK_NSZ_BIN=/usr/bin/nsz
# prod.keys location for NSP/XCI/NSZ/XCZ decryption. Default matches the
# legacy tinfoil-hat /keys mount layout. Required for any keyed
# extractor — the provider checks and skips silently if missing.
COOK_PROD_KEYS_PATH=/keys/prod.keys
# Per-extraction subprocess deadline (ms). Multi-gigabyte XCI dumps +
# NSZ decompress on a busy box can blow past 2 min — and a timeout means
# that title's NAME/ICON never gets extracted, so it falls back to the
# (often garbage) filename. Default is 10 min; raise further on slow disks
# or a heavily loaded server. See /healthz nameHealth + the dashboard panel.
COOK_EXTRACT_TIMEOUT_MS=600000

# Auto-extraction size cap (GB). Even in "missing" mode, a genuinely-uncovered
# giant container (≥6 GB XCI / NSZ) shouldn't be allowed to grind for minutes
# and hit the timeout above — it's SKIPPED and keeps its filename fallback
# (rare, acceptable). 0 or negative disables the cap (unlimited). Default 4.
COOK_EXTRACT_MAX_GB=4
# Inter-job pacing (ms) for the background extraction worker — a small gap
# between jobs so the one-time pass runs gently and never saturates disk/CPU
# while serving shop requests. Concurrency is unchanged; this only spaces jobs
# out. 0 disables the delay. Default 250.
COOK_EXTRACT_PACE_MS=250
