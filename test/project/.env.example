# Test-specific environment for the Playwright CI suite.
# The workflow copies this file to test/project/.env before launching the
# server. Values here are tuned to what the test specs assert; do not change
# without updating the specs (test/switch/*.spec.ts).
DEBUG=oc-cookingfoil*
COOK_PORT=3001
COOK_GAMES_DIR=./games
COOK_AUTH_USERS=admin:123
COOK_WELCOME_MSG=The Server Works!!
COOK_UNAUTHORIZED_MSG=No tricks and treats for you!!
COOK_TITLEDB_AUTO_FETCH=false
